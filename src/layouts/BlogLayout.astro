---
import Layout from "./Layout.astro";
interface Props {
	title: string;
	description: string;
	date: Date;
	tags?: string[];
}
const { title, description, date, tags } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
	timeZone: "UTC",
});
---

<Layout title={title} description={description}>
	<main class="max-w-2xl mx-auto px-6 py-16">
		<a
			href="/blog"
			class="text-sm text-neutral-500 hover:text-neutral-800 dark:hover:text-neutral-200 transition-colors mb-8 inline-block"
			>← Blog</a
		>
		<h1 class="text-3xl font-medium mb-2">{title}</h1>
		<div class="flex items-center gap-4 mb-6">
			<time class="text-sm text-neutral-400">{formattedDate}</time>
		</div>
		{
			tags && (
				<div class="flex flex-wrap gap-2 mb-10">
					{tags.map((tag) => (
						<span class="text-xs px-2 py-1 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400">
							{tag}
						</span>
					))}
				</div>
			)
		}
		<article class="prose prose-neutral dark:prose-invert max-w-none">
			<slot />
		</article>
	</main>
</Layout>
