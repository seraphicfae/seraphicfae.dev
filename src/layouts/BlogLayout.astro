---
import { Icon } from "astro-icon/components";
import Layout from "./Layout.astro";
interface Props {
	title: string;
	description: string;
	date: Date;
	readTime?: string;
}
const { title, description, date, readTime } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
	timeZone: "UTC",
});
---

<Layout title={title} description={description}>
	<main class="mx-auto max-w-2xl px-6 py-16">
		<a
			href="/blog"
			class="mb-8 inline-block text-sm text-neutral-500 transition-colors hover:text-neutral-800 dark:hover:text-neutral-200"
			>← Blog</a
		>
		<h1 class="mb-2 text-3xl font-medium">{title}</h1>
		<h2 class="mb-2">{description}</h2>
		<div class="mb-10 flex items-center gap-2">
			<time class="text-sm text-neutral-400" datetime={date.toISOString()}
				>{formattedDate}</time
			>
			<Icon name="lucide:dot" />
			<span class="text-sm text-neutral-400">{readTime}</span>
		</div>
		<article class="prose prose-neutral dark:prose-invert max-w-none">
			<slot />
		</article>
	</main>
</Layout>
