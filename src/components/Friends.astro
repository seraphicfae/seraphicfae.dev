---
import friends from "../data/friends.json";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
---

<section class="flex flex-col gap-3">
	<div class="flex items-center gap-2">
		<Icon name="lucide:user-plus" class="size-4 shrink-0" />
		<h2 class="font-black tracking-widest uppercase">friends</h2>
	</div>
	<div class="flex flex-wrap gap-3">
		{
			friends.map((friend) => (
				<a
					href={friend.source}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={friend.name}
					class="group relative"
				>
					<Image
						src={friend.avatar}
						alt={friend.name}
						width={180}
						height={180}
						loading="eager"
						decoding="async"
						class="h-10 w-10 rounded-xl object-cover ring-2 ring-transparent transition-all group-hover:ring-neutral-300 dark:group-hover:ring-neutral-600"
					/>
					<span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 rounded bg-neutral-900 px-2 py-1 text-xs whitespace-nowrap text-white opacity-0 transition-opacity group-hover:opacity-100 dark:bg-neutral-100 dark:text-neutral-900">
						{friend.name}
					</span>
				</a>
			))
		}
	</div>
</section>
