---
import { Icon } from "astro-icon/components";

const nav = [
	{
		label: "/home/meimei",
		ariaLabel: "Home",
		href: "/",
		icon: "lucide:house",
	},
	{
		label: "/bin/projects",
		ariaLabel: "Projects",
		href: "/projects",
		icon: "lucide:git-branch",
	},
	{
		label: "/var/blog",
		ariaLabel: "Blog",
		href: "/blog",
		icon: "lucide:notebook",
	},
];

const { pathname } = Astro.url;
const isCurrent = (href: string) =>
	href === "/" ? pathname === href : pathname.startsWith(href);
---

<header
	class="sticky top-0 z-50 w-full border-b border-neutral-200 bg-white/80 backdrop-blur-sm dark:border-neutral-800 dark:bg-neutral-950/80"
>
	<div class="mx-auto flex h-14 max-w-4xl items-center justify-between px-6">
		<img src="/favicon.svg" alt="favicon svg" class="block h-7 w-7" />
		<nav class="flex items-center gap-1">
			{
				nav.map(({ label, ariaLabel, href, icon }) => (
					<a
						href={href}
						aria-label={ariaLabel}
						aria-current={isCurrent(href) ? "page" : undefined}
						class:list={[
							"relative flex items-center gap-1.5 px-3 py-1.5 text-sm transition-colors duration-200",
							"after:absolute after:right-3 after:bottom-0 after:left-3 after:h-0.5 after:rounded-full after:bg-current",
							"after:origin-center after:transition-transform after:duration-300",
							isCurrent(href)
								? "text-neutral-900 after:scale-x-100 dark:text-neutral-100"
								: "text-neutral-500 after:scale-x-0 hover:text-neutral-900 hover:after:scale-x-100 dark:text-neutral-400 dark:hover:text-neutral-100",
						]}
					>
						{icon && <Icon name={icon} class="size-4" />}
						<span class="text-s hidden sm:block">{label}</span>
					</a>
				))
			}
		</nav>
	</div>
</header>
