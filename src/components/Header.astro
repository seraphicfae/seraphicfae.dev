---
import { Icon } from 'astro-icon/components';

const nav = [
  { label: '/home/meimei', ariaLabel: 'Home', href: '/', icon: 'lucide:house' },
  { label: '/bin/projects', ariaLabel: 'Projects', href: '/projects', icon: 'lucide:git-branch' },
];

const { pathname } = Astro.url;
const isCurrent = (href: string) =>
  href === '/' ? pathname === href : pathname.startsWith(href);
---

<header class="sticky top-0 z-50 w-full border-b border-neutral-200 dark:border-neutral-800 bg-white/80 dark:bg-neutral-950/80 backdrop-blur-sm">
  <div class="max-w-4xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="transition-opacity hover:opacity-75">
      <span class="hidden sm:block font-medium text-sm text-neutral-900 dark:text-neutral-100">seraphicfae</span>
      <img src="/favicon.svg" alt="seraphicfae" class="block sm:hidden w-7 h-7" />
    </a>
    <nav class="flex items-center gap-1">
      {nav.map(({ label, ariaLabel, href, icon }) => (
        <a
          href={href}
          aria-label={ariaLabel}
          aria-current={isCurrent(href) ? 'page' : undefined}
          class:list={[
            "relative px-3 py-1.5 rounded-md text-sm flex items-center gap-1.5 transition-colors duration-200 overflow-hidden",
            isCurrent(href)
              ? "text-neutral-900 dark:text-neutral-100"
              : "text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100"
          ]}
        >
          {icon && <Icon name={icon} class="size-4" />}
          <span class="hidden sm:block font-mono text-xs">{label}</span>
          <span class:list={[
            "absolute bottom-0 left-3 right-3 h-0.5 rounded-full bg-neutral-900 dark:bg-neutral-100 transition-all duration-300 origin-left",
            isCurrent(href) ? "scale-x-100 opacity-100" : "scale-x-0 opacity-0"
          ]} />
        </a>
      ))}
      <a
        href="https://github.com/seraphicfae/seraphicfae.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-2 p-1.5 text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
        aria-label="GitHub source"
      >
        <Icon name="lucide:github" class="size-4" />
      </a>
    </nav>
  </div>
</header>
