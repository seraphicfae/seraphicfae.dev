---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import ReviewDB from "../components/ReviewDB.astro";
import Friends from "../components/Friends.astro";
import TechStack from "../components/TechStack.astro";
import Profile from "../components/Profile.astro";
---

<Layout
	title="Home"
	description="About me, tech stack, friends, and reviewdb all found here!"
>
	<div class="mx-auto max-w-5xl px-6 py-16">
		<div class="grid grid-cols-1 gap-x-16 gap-y-12 md:grid-cols-2">
			<!-- LEFT COLUMN -->
			<div class="flex flex-col gap-12">
				<Profile />

				<!-- about me -->
				<section class="flex flex-col gap-3">
					<div class="flex items-center gap-2">
						<Icon name="lucide:pen-line" class="size-4 shrink-0" />
						<h2 class="font-black tracking-widest uppercase">About me</h2>
					</div>
					<p
						class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-300"
					>
						Junior front-end web developer with an interest in Docker, Linux,
						and DevOps. Obsessing over standards in Linux, Wayland development,
						and freedesktop specifications. Outside of dev work I'm into
						emulation, indie games, and multimedia formats like Opus and JXL.
					</p>
				</section>
				<TechStack />
			</div>

			<!-- RIGHT COLUMN -->
			<div class="flex flex-col gap-12">
				<Friends />
				<ReviewDB />
			</div>
		</div>
	</div>
</Layout>
